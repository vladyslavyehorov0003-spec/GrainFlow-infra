# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Secrets ───────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Database (prod only — points to RDS) ─────────────────────────────────────
DB_USERNAME=
DB_PASSWORD=
AUTH_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/grainflow_auth
WAREHOUSE_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/grainflow_warehouse
PAYMENT_DB_URL=jdbc:postgresql://<rds-endpoint>:5432/grainflow_payment

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

#email
MAIL_PASSWORD=
MAIL_USERNAME=
APP_BASE_URL=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=

# ── ECR (prod only) ───────────────────────────────────────────────────────────
# Format: <aws-account-id>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY=
IMAGE_TAG=latest
